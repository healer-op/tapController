{
  "name": "tapcontroller",
  "productName": "TapController",
  "version": "1.0.0",
  "description": "Turn your phone into a game controller for PC",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect=5858",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "publish:win": "electron-builder --win -p always",
    "prebuild": "taskkill /F /IM TapController.exe /T 2>$null || set ERRORLEVEL=0 && Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue || set ERRORLEVEL=0",
    "postinstall": "echo Install complete. Run 'pip install vgamepad' if not done already. ViGEmBus installer is bundled at tools/drivers/ViGEmBus_1.22.0_x64_x86_arm64.exe."
  },
  "dependencies": {
    "cloudflared": "^0.7.1",
    "express": "^4.18.2",
    "ip": "^2.0.0",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.tapcontroller.app",
    "productName": "TapController",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "healer-op",
        "repo": "tapController"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "tools/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/cloudflared/bin",
        "to": "bin"
      },
      {
        "from": "tools",
        "to": "tools"
      }
    ]
  }
}
